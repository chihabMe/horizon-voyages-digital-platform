datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Booking {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  reference      String        @unique // Booking reference (e.g., HV-12345)
  clientName     String
  clientEmail    String
  clientPhone    String
  status         BookingStatus @default(PENDING)
  totalAmount    Float
  departureDate  DateTime
  returnDate     DateTime
  tripTitle      String
  numberOfPeople Int
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model VisaRequest {
  id          String     @id @default(cuid())
  fullName    String
  email       String
  phone       String
  nationality String
  destination String
  visaType    String
  notes       String?
  status      FormStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model GroupTripRequest {
  id             String     @id @default(cuid())
  fullName       String
  email          String
  phone          String
  destination    String
  departureDate  DateTime
  durationDays   Int
  numberOfPeople Int
  budgetRange    String
  notes          String?
  status         FormStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ContactRequest {
  id        String     @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    FormStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum FormStatus {
  PENDING
  REVIEWED
  RESOLVED
}
